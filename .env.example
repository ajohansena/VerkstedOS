# ---------------------------------------------------------------------------
# VerkstedOS environment variables
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# Deployed environments set these in the Vercel project dashboard.
# ---------------------------------------------------------------------------

# --- Supabase (EU region — Stockholm or Frankfurt) -------------------------
# Project URL and anon key are public (shipped to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is SECRET — server-only, never exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string (pooled) used by Drizzle for TENANT operations.
# In production this must be a NON-superuser role so RLS is enforced.
DATABASE_URL=
# Service-role connection for admin/bootstrap/platform operations (bypasses RLS).
# In Supabase this is the service-role connection. Optional in local dev — falls
# back to DATABASE_URL when unset.
DATABASE_URL_ADMIN=

# --- Inngest ----------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Sentry -----------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
# Used only for source-map upload during build; optional locally.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- App --------------------------------------------------------------------
# Public base URL of this deployment (used for auth redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- External lookups (Sprint 5) --------------------------------------------
# Statens vegvesen registration-plate lookup. Adapter returns "not_configured"
# until set; cache + parsing contract work without it.
VEGVESEN_API_KEY=
# 1881 / Sveve phone-directory lookup.
SVEVE_1881_API_KEY=

# --- Dev Control Plane ------------------------------------------------------
# Comma-separated IP allow-list for the /dev surface in production.
PLATFORM_ALLOWED_IPS=
